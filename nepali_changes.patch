+
+void main() {
+  Future<TextEditingController> pump(
+    WidgetTester tester, {
+    VoidCallback? onDone,
+  }) async {
+    final controller = TextEditingController();
+    await tester.pumpWidget(
+      MaterialApp(
+        home: Scaffold(
+          body: NepaliKeyboard(controller: controller, onDone: onDone),
+        ),
+      ),
+    );
+    return controller;
+  }
